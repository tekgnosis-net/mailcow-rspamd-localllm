# Copy to .env next to docker-compose.yaml; docker compose reads it automatically.

# Upstream OpenAI-compatible LLM endpoint (vLLM, llama.cpp, or Ollama).
# Inside the container 127.0.0.1 is the container itself — point at a
# reachable host or service name instead.
LLM_API=http://127.0.0.1:8000/v1

# Web search provider used to enrich prompts: "ddgs" (default) or "firecrawl".
SEARCH_PROVIDER=ddgs

# Base URL of your self-hosted Firecrawl instance (only used when
# SEARCH_PROVIDER=firecrawl). This can also point at a firecrawl-dashboard
# transparent proxy (e.g. http://firecrawl-dashboard:3101) so searches show
# up in its metrics.
#FIRECRAWL_API_URL=http://firecrawl:3002

# Optional: only needed if your Firecrawl instance enforces authentication.
#FIRECRAWL_API_KEY=fc-your-key
